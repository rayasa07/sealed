# Solana devnet RPC. Helius / QuickNode / Triton all work; the public devnet
# endpoint will rate-limit you and break the experience.
NEXT_PUBLIC_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Deployed program ID. Already filled in for the Sealed devnet deployment.
NEXT_PUBLIC_PROGRAM_ID=6K6aykKN8vrBg8RQDtpeJXm6KUo5hG3KFYfyWdi5YS1e

# Arcium devnet cluster offset. 456 is the canonical devnet value.
NEXT_PUBLIC_ARCIUM_CLUSTER_OFFSET=456
